@using System.Globalization
@using Blazored.LocalStorage
@using Microsoft.Extensions.Localization
@using tci.FileFlow.SftpEngine.Core.Services
@using System.IO
@inherits LayoutComponentBase
@inject ILocalStorageService LocalStorage
@inject IStringLocalizer<MainLayout> Loc
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IDatabaseService DbService
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IAuthService AuthService

<PageTitle>@(string.IsNullOrWhiteSpace(_clientName) ? "SFTP Engine" : $"{_clientName} - SFTP Engine")</PageTitle>

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" Theme="_myCustomTheme" />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.ExtraExtraLarge" />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Fixed="true">
        @if (_hasLogo)
        {
            <img src="@($"images/client-logo.png?v={_logoCacheBuster}")" alt="Logo" style="height: 40px; margin-right: 15px;" />
        }
        <MudText Typo="Typo.h6" Class="ml-3">@(string.IsNullOrWhiteSpace(_clientName) ? "SFTP Engine" : _clientName)</MudText>

        <MudSpacer />

        <MudMenu Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" AnchorOrigin="Origin.TopRight"
                 TransformOrigin="Origin.TopRight">
            
            @if (AuthService.IsAuthenticated)
            {
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">@Loc["Logout"]</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.Key" OnClick="OpenChangePasswordDialog">@Loc["ChangePassword"]</MudMenuItem>
            }
            else
            {
                <MudMenuItem Icon="@Icons.Material.Filled.Login" OnClick="OpenLoginDialog">@Loc["Login"]</MudMenuItem>
            }
            <MudDivider />

            <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="OpenConfigDialogAsync">
                @Loc["ConfigButton"]
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Analytics" OnClick="OpenDiagnosticsDialogAsync">
                @Loc["DiagnosticsButton"]
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Brush" OnClick="@OpenBrandingDialog">
                @Loc["Branding"]
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem OnClick="@ToggleDarkMode">
                @(_isDarkMode ? Loc["LightMode"] : Loc["DarkMode"])
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem Disabled="true">@Loc["Language"]</MudMenuItem>
            <MudMenuItem Disabled="@(_currentCulture == "en")" OnClick="@(() => SelectCulture("en"))">@Loc["English"]
            </MudMenuItem>
            <MudMenuItem Disabled="@(_currentCulture == "es")" OnClick="@(() => SelectCulture("es"))">@Loc["Spanish"]
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode;
    private string _currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    private string _clientName = string.Empty;
    private bool _hasLogo;
    private long _logoCacheBuster;

    protected override void OnInitialized()
    {
        AuthService.OnAuthStateChanged += StateHasChanged;
        RefreshBrandingData();
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }

    private void RefreshBrandingData()
    {
        _clientName = DbService.GetActiveConfig().ClientName;
        var webRoot = Env.WebRootPath ?? Path.Combine(Env.ContentRootPath, "wwwroot");
        var logoPath = Path.Combine(webRoot, "images", "client-logo.png");
        _hasLogo = File.Exists(logoPath);
        _logoCacheBuster = DateTime.UtcNow.Ticks;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await LocalStorage.GetItemAsync<bool>("darkMode");
            StateHasChanged();
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await LocalStorage.SetItemAsync("darkMode", _isDarkMode);
    }
    
    private async Task OpenBrandingDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<tci.FileFlow.SftpEngine.Blazor.Components.Pages.Branding>("Branding", options);
        var result = await dialog.Result;
        
        if (!result.Canceled)
        {
            RefreshBrandingData();
            StateHasChanged();
        }
    }

    private async Task OpenLoginDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<tci.FileFlow.SftpEngine.Blazor.Components.Shared.LoginModal>("Login", options);
    }

    private void Logout()
    {
        AuthService.Logout();
    }

    private async Task OpenChangePasswordDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<tci.FileFlow.SftpEngine.Blazor.Components.Shared.ChangePasswordModal>("Change Password", options);
    }

    private async Task OpenConfigDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        await DialogService.ShowAsync<tci.FileFlow.SftpEngine.Blazor.Components.Pages.Configuration>("Configuration", options);
    }

    private async Task OpenDiagnosticsDialogAsync()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large, FullWidth = true };
        await DialogService.ShowAsync<tci.FileFlow.SftpEngine.Blazor.Components.Pages.Diagnostics>("Diagnostics", options);
    }

    private void SelectCulture(string culture)
    {
        if (culture == _currentCulture)
            return;

        var uri = new Uri(NavigationManager.Uri).GetComponents(UriComponents.PathAndQuery, UriFormat.Unescaped);
        var query = $"?culture={Uri.EscapeDataString(culture)}&redirectUri={Uri.EscapeDataString(uri)}";
        NavigationManager.NavigateTo("/Culture/Set" + query, forceLoad: true);
    }

    private MudTheme _myCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#0054a6",
            Secondary = "#00818a",
            AppbarBackground = "#0054a6",
            Surface = "#ffffff",
            Background = "#f4f7f9",
            Success = "#2e7d32",
            PrimaryContrastText = "#ffffff",
            SuccessContrastText = "#ffffff"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#4db6ac",
            Secondary = "#80deea",
            Background = "#121212",
            Surface = "#1e1e1e",
            AppbarBackground = "#1a1a1a",
            DrawerBackground = "#121212",
            ActionDefault = "#b0bec5",
            TextPrimary = "#eceff1",
            Success = "#2e7d32",
            SuccessContrastText = "#ffffff",
            PrimaryContrastText = "#121212",
            InfoContrastText = "#ffffff",
            WarningContrastText = "#121212"
        }
    };
}